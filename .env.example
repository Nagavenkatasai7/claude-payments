# Ollama Cloud (Kimi K2.6)
OLLAMA_BASE_URL=https://ollama.com/v1
OLLAMA_API_KEY=
OLLAMA_MODEL=

# Meta WhatsApp Cloud API
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=choose-any-string
# Meta App Secret — verifies the X-Hub-Signature-256 header on inbound webhooks.
# Unset ⇒ the /api/whatsapp POST handler skips verification (warns; dev/test +
# current prod). Set ⇒ requests with a bad/missing signature are rejected (401).
META_APP_SECRET=

# Public origin of the deployed app (used to build payment links)
APP_BASE_URL=https://your-app.vercel.app

# Upstash Redis (added automatically by the Vercel Marketplace integration)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# P3 — partner-staff seed (optional). Set together to seed a partner-scoped
# staff member on first request. Used by the Playwright E2E smoke.
SEED_PARTNER_USERNAME=
SEED_PARTNER_PASSWORD=
SEED_PARTNER_ID=

# Payment-provider seam (pay-seam). v1 only supports 'mock' (default). Forward hook.
PAYMENT_PROVIDER_MODE=mock
# Per-provider webhook HMAC secret, keyed by upper-cased provider name.
# Unset ⇒ the /api/payment-webhook/<provider> route rejects real-provider callbacks (fail-closed).
# PAYMENT_WEBHOOK_SECRET_UNITELLER=

# Optional. 'true' enables the WhatsApp interactive-list primitive for the
# recipient picker; anything else (default) uses 3-button messages. Falls back
# to buttons on any list-send failure. Requires a Meta-Business-verified WABA.

# ── Email (Hostinger SMTP, via nodemailer) ───────────────────────────────────
# Powers "Partner with us" lead notifications. ALL OPTIONAL: if unset, the email
# effect no-ops and the lead still lands in /admin-dashboard/partner-requests.
# SMTP_USER is the FULL mailbox address; SMTP_PASS is that mailbox's password
# (Hostinger has no separate SMTP key). EMAIL_FROM's address MUST equal SMTP_USER
# (Hostinger 550s a mismatched From; display-name aliasing is fine).
# SMTP_HOST=smtp.hostinger.com
# SMTP_PORT=465
# SMTP_USER=venkat@smartremit.ai
# SMTP_PASS=
# EMAIL_FROM=SmartRemit <venkat@smartremit.ai>
# Recipients of partner-lead emails — comma-separated; add more any time.
# PARTNER_LEAD_EMAILS=venkat@smartremit.ai
